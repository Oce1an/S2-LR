{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Task3",
            "type": "shell",
            "command": "g++",
            "args": [
                "-std=c++17",
                "-Wall",
                "-Wextra",
                "-g",
                "-o",
                "Task3",
                "main.cpp",
                "number.cpp",
                "binaryop.cpp",
                "check.cpp"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++-13 сборка активного файла",
            "command": "/usr/bin/g++-13",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${fileDirname}/binaryop.cpp",
                "${fileDirname}/check.cpp",
                "${fileDirname}/main.cpp",
                "${fileDirname}/number.cpp",

                "-o",
                "${fileDirname}/main"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Задача создана отладчиком."
        }
    ]
}